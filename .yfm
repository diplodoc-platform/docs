allowHtml: true
langs: ['ru','en']

vcs: true
mtimes: true
authors: true

search:
  provider: local

interface:
  toc-header: false
  favicon-src: https://storage.yandexcloud.net/diplodoc-www-assets/favicon/favicon.ico

extensions:
  - name: mdit-plugins
    plugins:
    - '@diplodoc/transform/lib/plugins/checkbox'
  - github-vcs

preprocess:
  mergeIncludes: true

resources:
  style:
    - _assets/style/custom.css
  csp:
    - "frame-src":
        - "https://vk.com"
        - "https://login.vk.com"
        - "https://runtime.strm.yandex.ru"
    - "img-src":
        - "data:"
        - "https://storage.yandexcloud.net"
    - "style-src":
        - "fonts.googleapis.com"

analytics:
  metrika:
    - id: 94828406

docs-viewer:
  project-name: diplodoc
  langs: ['ru','en']
  favicon-src: https://storage.yandexcloud.net/diplodoc-www-assets/favicon/favicon.ico
  github-url-prefix: https://github.com/diplodoc-platform/docs/blob/master
  logo-link-preview: https://storage.yandexcloud.net/diplodoc-www-assets/navigation/diplodoc-logo.svg
  logo-options:
    src: https://storage.yandexcloud.net/diplodoc-www-assets/navigation/diplodoc-logo.svg
    src-dark: https://storage.yandexcloud.net/diplodoc-www-assets/logo/ddos-logo-dark.svg
    src-preview:
      ru: https://storage.yandexcloud.net/diplodoc-www-assets/navigation/diplodoc-share-doc-ru.png
      default: https://storage.yandexcloud.net/diplodoc-www-assets/navigation/diplodoc-share-doc-eng.png
    title: Diplodoc
    img-has:
      width: 158px
      offset: true
  ytm:
    id: 94828406
